rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Superadmin — full visibility across all users, can change priority
    function isSuperAdmin() {
      return request.auth != null &&
             request.auth.token.email == 'bhandakarsrinivas.automation@gmail.com';
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Fields an admin is allowed to touch on someone else's task:
    // only 'priority' and 'updatedAt' — nothing else.
    function isAdminPriorityOnlyChange() {
      let changed = request.resource.data.diff(resource.data).affectedKeys();
      return changed.hasOnly(['priority', 'updatedAt']);
    }

    // ---------------- USERS ----------------
    // Lightweight profile doc per user (name/email/photo), used by admin
    // to show "which user owns which task". Each user manages only their
    // own doc; superadmin can read all of them.
    match /users/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow create, update: if isOwner(userId);
      allow delete: if false;
    }

    // ---------------- TASKS ----------------
    match /tasks/{taskId} {
      // Read: owner can read their own tasks; superadmin can read all
      allow read: if isOwner(resource.data.uid) || isSuperAdmin();

      // Create: only signed-in users, and only for themselves
      allow create: if isSignedIn() &&
                       request.resource.data.uid == request.auth.uid &&
                       request.resource.data.title is string &&
                       request.resource.data.title.size() > 0 &&
                       request.resource.data.priority in ['High', 'Medium', 'Low'];

      // Update: owner can fully edit their own task (uid must stay the same);
      // superadmin can ONLY change priority (+ updatedAt) on anyone's task.
      allow update: if (isOwner(resource.data.uid) &&
                          request.resource.data.uid == resource.data.uid &&
                          request.resource.data.priority in ['High', 'Medium', 'Low']) ||
                       (isSuperAdmin() &&
                          isAdminPriorityOnlyChange() &&
                          request.resource.data.priority in ['High', 'Medium', 'Low']);

      // Delete: only the owner can delete their own task
      allow delete: if isOwner(resource.data.uid);
    }
  }
}
